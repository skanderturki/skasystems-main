# nadart-evo environment variables
NADART_JWT_SECRET=your-secure-jwt-secret-here
NADART_ADMIN_EMAIL=nadart.galery@gmail.com
NADART_ADMIN_PASSWORD=your-secure-password-here
NADART_GOOGLE_CLIENT_ID=your-google-client-id
NADART_N8N_AUTH_USER=nadart
NADART_N8N_AUTH_PASSWORD=your-n8n-auth-password

# pmp-website environment variables
PMP_MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/pmp-learning
PMP_JWT_SECRET=your-secure-jwt-secret-here
PMP_SMTP_HOST=smtp.gmail.com
PMP_SMTP_PORT=587
PMP_SMTP_USER=your-email@gmail.com
PMP_SMTP_PASS=your-google-app-password

# Main website (react-app) environment variables
# The main website's /api/contact endpoint uses Resend (same key as PMP).
# PMP_RESEND_API_KEY above is reused — no separate key needed.
MAIN_RESEND_FROM=SKA Systems <noreply@skasystems.com>
MAIN_CONTACT_TO_EMAIL=skanderturki@gmail.com
